# Copy values into Coolify environment settings only when you need to override defaults.
# Do not store real production secrets in this repository.

# Public domain routed by Coolify to new-api:3000.
SERVICE_FQDN_NEWAPI_3000=https://llmapi.1983070.xyz

# Optional image pin. For production, prefer a tested version tag over latest.
NEW_API_IMAGE=calciumion/new-api:latest

# Non-secret runtime settings.
TZ=Asia/Shanghai
POSTGRES_USER=newapi
POSTGRES_DB=newapi
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
NODE_NAME=new-api-coolify-1
STREAMING_TIMEOUT=300
STREAM_SCANNER_MAX_BUFFER_MB=128
MAX_REQUEST_BODY_MB=128
TRUSTED_REDIRECT_DOMAINS=1983070.xyz

# Coolify can generate and persist these SERVICE_PASSWORD_* values automatically.
# Set manually only when you need deterministic values, and keep them in Coolify secrets.
SERVICE_PASSWORD_POSTGRES=replace-with-url-safe-postgres-password
SERVICE_PASSWORD_REDIS=replace-with-url-safe-redis-password
SERVICE_PASSWORD_SESSION=replace-with-random-session-secret
SERVICE_PASSWORD_CRYPTO=replace-with-random-crypto-secret
